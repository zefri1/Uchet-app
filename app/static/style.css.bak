:root {
    --bg: #f3efe6;
    --panel: rgba(255, 255, 255, 0.78);
    --ink: #1f2a2c;
    --muted: #60706e;
    --accent: #b05d2d;
    --accent-dark: #7a3f1e;
    --line: rgba(31, 42, 44, 0.12);
    --shadow: 0 18px 45px rgba(65, 44, 29, 0.12);
}

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    background:
        radial-gradient(circle at top left, rgba(176, 93, 45, 0.18), transparent 28%),
        linear-gradient(135deg, #f8f4eb 0%, #efe7d8 100%);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
}

.sidebar {
    padding: 32px 24px;
    background: rgba(29, 35, 36, 0.92);
    color: #fff6ea;
}

.logo-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
}

.logo-img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
}

.sidebar h1 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.01em;
}

.sidebar nav {
    display: grid;
    gap: 10px;
    margin: 30px 0;
}

.sidebar a {
    color: #fff6ea;
    text-decoration: none;
    padding: 10px 12px;
    border: 1px solid rgba(255, 246, 234, 0.16);
    border-radius: 12px;
}

.stats {
    display: grid;
    gap: 14px;
}

.stats div {
    padding: 14px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.08);
}

.stats strong {
    display: block;
    font-size: 1.8rem;
}

.content {
    padding: 30px;
}

.hero {
    margin-bottom: 20px;
    padding: 26px 30px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(255, 250, 244, 0.9), rgba(255, 255, 255, 0.56));
    box-shadow: var(--shadow);
}

.eyebrow {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
}

.hero h2,
.card h3 {
    margin: 0;
    font-weight: 600;
    letter-spacing: -0.01em;
}

.grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.grid.two-forms {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.card {
    background: var(--panel);
    backdrop-filter: blur(14px);
    border-radius: 22px;
    box-shadow: var(--shadow);
    border: 1px solid rgba(255, 255, 255, 0.7);
    overflow: hidden;
}

.form-card {
    padding: 22px;
}

.table-card {
    padding: 22px;
    overflow-x: auto;
}

form {
    display: grid;
    gap: 14px;
}

label {
    display: grid;
    gap: 6px;
    font-size: 0.95rem;
}

input,
select,
textarea,
button {
    font: inherit;
}

input:not([type="checkbox"]),
select,
textarea {
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.9);
}

button {
    padding: 11px 14px;
    border: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: white;
    cursor: pointer;
}

.form-error {
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid rgba(176, 93, 45, 0.28);
    background: rgba(176, 93, 45, 0.12);
    color: #7a3f1e;
    font-size: 0.95rem;
    line-height: 1.35;
}

.checkbox {
    grid-auto-flow: column;
    justify-content: start;
    align-items: center;
    gap: 10px;
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
    font-size: 0.95rem;
}

th,
td {
    padding: 10px 8px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
}

.actions,
.inline-form {
    display: flex;
    gap: 8px;
    align-items: center;
}

.inline-form input {
    width: 100px;
}

a {
    color: var(--accent-dark);
}

@media (max-width: 1100px) {
    .layout {
        grid-template-columns: 1fr;
    }

    .sidebar {
        padding-bottom: 18px;
    }

    .grid,
    .grid.two-forms {
        grid-template-columns: 1fr;
    }
}

/* Dialog Modals */
dialog {
    border: none;
    border-radius: 22px;
    background: #f8f4eb;
    box-shadow: 0 24px 60px rgba(65, 44, 29, 0.24);
    padding: 24px;
    width: 95%;
    max-width: 500px;
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
}

dialog::backdrop {
    background: rgba(31, 42, 44, 0.4);
    backdrop-filter: blur(5px);
}

dialog h3 {
    margin-top: 0;
    margin-bottom: 12px;
    color: var(--accent-dark);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding-bottom: 10px;
    margin-bottom: 15px;
}

.modal-header h3 {
    margin: 0;
}

.btn-close {
    background: transparent;
    border: none;
    font-size: 1.25rem;
    color: var(--muted);
    cursor: pointer;
    padding: 0;
    line-height: 1;
}

.btn-close:hover {
    color: var(--ink);
}

.danger-btn {
    background: linear-gradient(135deg, #d32f2f, #b71c1c);
}

.edit-btn {
    background: #eee;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 0.85rem;
    cursor: pointer;
    font-weight: 500;
}

.edit-btn:hover {
    background: #e0e0e0;
}

.delete-btn-inline {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 1.1rem;
    display: inline-flex;
    align-items: center;
}

