{% extends "base.html" %}
{% block content %}
<section class="hero">
    <div>
        <p class="eyebrow">Расчет начислений</p>
        <h2>Периоды и начисления</h2>
    </div>
</section>
{% if error %}
<div class="form-error" style="margin: 0 2rem 1.5rem 2rem;">{{ error }}</div>
{% endif %}
<section class="grid">
    <form class="card form-card" method="post" action="/billing/periods">
        <h3>Создать период</h3>
        <label>Тип периода
            <select name="period_type">
                <option value="month">Месяц</option>
                <option value="range">Диапазон</option>
            </select>
        </label>
        <label>Ярлык месяца<input name="month_label" placeholder="2026-06"></label>
        <label>Дата начала<input name="start_date" type="date" required></label>
        <label>Дата окончания<input name="end_date" type="date" required></label>
        <button type="submit">Создать период</button>
    </form>
    <div class="card table-card">
        <h3>Периоды</h3>
        <table>
            <thead><tr><th>Период</th><th>Тип</th><th>Статус</th><th>Действия</th></tr></thead>
            <tbody>
            {% for item in periods %}
                <tr>
                    <td><a href="/billing?period_id={{ item.id }}">{{ item.month_label or (item.start_date ~ " - " ~ item.end_date) }}</a></td>
                    <td>{{ period_type_labels.get(item.period_type, item.period_type) }}</td>
                    <td>{{ status_labels.get(item.status, item.status) }}</td>
                    <td class="actions">
                        {% if item.status == "closed" %}
                            <form method="post" action="/billing/{{ item.id }}/reopen" style="margin: 0;">
                                <button type="submit" style="background: linear-gradient(135deg, #f57c00, #e65100);">Открыть заново</button>
                            </form>
                        {% else %}
                            <form method="post" action="/billing/{{ item.id }}/calculate" style="margin: 0;">
                                <button type="submit">Рассчитать</button>
                            </form>
                            {% if item.status == "calculated" %}
                                <form method="post" action="/billing/{{ item.id }}/close" style="margin: 0;">
                                    <button type="submit" style="background: linear-gradient(135deg, #2e7d32, #1b5e20);">Закрыть</button>
                                </form>
                            {% endif %}
                            <form method="post" action="/billing/{{ item.id }}/reset" style="margin: 0;" onsubmit="return confirm('Вы уверены, что хотите сбросить все ручные корректировки и пересчитать период с нуля?');">
                                <button type="submit" style="background: linear-gradient(135deg, #d32f2f, #c62828);">Сбросить</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4">Периодов пока нет.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% if selected_period %}
<div style="margin-top: 2rem;">
    <div class="card table-card" style="margin-bottom: 2rem;">
        <h3>Начисления по периоду {{ selected_period.month_label or (selected_period.start_date ~ " - " ~ selected_period.end_date) }}</h3>
        <table>
            <thead><tr><th>Объект</th><th>Арендатор</th><th>Услуга</th><th>Площадь</th><th>Сумма</th><th>Корректировка</th></tr></thead>
            <tbody>
            {% for item in allocations %}
                <tr>
                    <td>{{ item.object.name }}</td>
                    <td>{{ item.tenant.display_name }}</td>
                    <td>{{ utility_labels[item.utility_charge.utility_type] }}</td>
                    <td>{{ item.base_area }}</td>
                    <td>{{ item.amount }}</td>
                    <td>
                        <form method="post" action="/billing/allocations/{{ item.id }}" class="inline-form">
                            <input name="amount" type="number" step="0.01" value="{{ item.amount }}" {% if selected_period.status == "closed" %}disabled{% endif %}>
                            <button type="submit" {% if selected_period.status == "closed" %}disabled{% endif %}>Обновить</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6">Сначала выполните расчет периода.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card table-card">
        <h3>Итоги по арендаторам</h3>
        <table>
            <thead><tr><th>Арендатор</th><th>Итого</th></tr></thead>
            <tbody>
            {% for tenant_name, total in totals.items() %}
                <tr><td>{{ tenant_name }}</td><td>{{ total }}</td></tr>
            {% else %}
                <tr><td colspan="2">Нет итогов.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
