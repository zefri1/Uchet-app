{% extends "base.html" %}
{% block content %}
<section class="hero">
    <div>
        <p class="eyebrow">Ввод счетов и настройка правил</p>
        <h2>Счета и распределение</h2>
    </div>
</section>
<section class="grid two-forms">
    <form class="card form-card" method="post" action="/charges">
        <h3>Добавить счет</h3>
        <label>Объект
            <select name="object_id" required>
                {% for item in objects %}<option value="{{ item.id }}">{{ item.name }}</option>{% endfor %}
            </select>
        </label>
        <label>Период
            <select name="billing_period_id" required>
                {% for item in periods %}<option value="{{ item.id }}">{{ item.month_label or (item.start_date ~ " - " ~ item.end_date) }}</option>{% endfor %}
            </select>
        </label>
        <label>Услуга
            <select name="utility_type">
                {% for key, label in utility_labels.items() %}<option value="{{ key }}">{{ label }}</option>{% endfor %}
            </select>
        </label>
        <label>Ввод
            <select name="input_mode">
                <option value="amount">Итоговой суммой</option>
                <option value="meter">По счетчику</option>
            </select>
        </label>
        <label>Распределение
            <select name="allocation_mode">
                <option value="area">По площади</option>
                <option value="manual">Вручную</option>
                <option value="mixed">Смешанное</option>
            </select>
        </label>
        <label>Сумма<input name="amount" type="number" step="0.01"></label>
        <label>Показание от<input name="meter_from" type="number" step="0.001"></label>
        <label>Показание до<input name="meter_to" type="number" step="0.001"></label>
        <label>Тариф<input name="tariff" type="number" step="0.0001"></label>
        <label>Ед. изм.<input name="unit_name"></label>
        <label>Комментарий<textarea name="comment" rows="3"></textarea></label>
        <button type="submit">Сохранить счет</button>
    </form>
    <form class="card form-card" method="post" action="/rules">
        <h3>Добавить правило</h3>
        <label>Объект
            <select name="object_id" required>
                {% for item in objects %}<option value="{{ item.id }}">{{ item.name }}</option>{% endfor %}
            </select>
        </label>
        <label>Услуга
            <select name="utility_type">
                {% for key, label in utility_labels.items() %}<option value="{{ key }}">{{ label }}</option>{% endfor %}
            </select>
        </label>
        <label>Режим
            <select name="mode">
                <option value="area">По площади</option>
                <option value="manual">Ручной</option>
                <option value="mixed">Смешанный</option>
            </select>
        </label>
        <label>База площади
            <select name="base_area_mode">
                <option value="active_leases">Сумма активных площадей</option>
                <option value="object_total">Общая площадь объекта</option>
            </select>
        </label>
        <label>Арендатор
            <select name="tenant_id">
                <option value="">Для всех арендаторов</option>
                {% for item in tenants %}<option value="{{ item.id }}">{{ item.display_name }}</option>{% endfor %}
            </select>
        </label>
        <label>Тип значения
            <select name="value_type">
                <option value="">Без ручной доли</option>
                <option value="percent">Процент</option>
                <option value="fixed">Фиксированная сумма</option>
            </select>
        </label>
        <label>Значение<input name="value" type="number" step="0.01"></label>
        <button type="submit">Сохранить правило</button>
    </form>
</section>
<div style="margin-top: 2rem;">
    <div class="card table-card" style="margin-bottom: 2rem;">
        <h3>Счета</h3>
        <table>
            <thead><tr><th>Объект</th><th>Период</th><th>Услуга</th><th>Ввод</th><th>Распределение</th><th>Сумма</th><th>Действия</th></tr></thead>
            <tbody>
            {% for item in charges %}
                <tr>
                    <td>{{ item.object.name }}</td>
                    <td>{{ item.billing_period.month_label or (item.billing_period.start_date ~ " - " ~ item.billing_period.end_date) }}</td>
                    <td>{{ utility_labels[item.utility_type] }}</td>
                    <td>{{ "Сумма" if item.input_mode == "amount" else "Счетчик" }}</td>
                    <td>{{ allocation_mode_labels.get(item.allocation_mode, item.allocation_mode) }}</td>
                    <td>{{ item.amount if item.amount is not none else "-" }}</td>
                    <td class="actions">
                        <button class="edit-btn" onclick="openEditChargeModal({{ item.id }}, {{ item.object_id }}, {{ item.billing_period_id }}, '{{ item.utility_type }}', '{{ item.input_mode }}', '{{ item.allocation_mode }}', '{{ item.amount or '' }}', '{{ item.meter_from or '' }}', '{{ item.meter_to or '' }}', '{{ item.tariff or '' }}', '{{ (item.unit_name or '')|escape }}', '{{ (item.comment or '')|escape }}')">✏️ Изменить</button>
                        <form method="post" action="/charges/{{ item.id }}/delete" style="margin: 0;" onsubmit="return confirm('Вы уверены? Удаление счета приведет к перерасчету начислений.');">
                            <button type="submit" class="delete-btn-inline">❌</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7">Счетов пока нет.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card table-card">
        <h3>Правила распределения</h3>
        <table>
            <thead><tr><th>Объект</th><th>Услуга</th><th>Режим</th><th>Арендатор</th><th>Тип</th><th>Значение</th><th>Действия</th></tr></thead>
            <tbody>
            {% for item in rules %}
                <tr>
                    <td>{{ item.object.name }}</td>
                    <td>{{ utility_labels[item.utility_type] }}</td>
                    <td>{{ allocation_mode_labels.get(item.mode, item.mode) }}</td>
                    <td>{{ item.tenant.display_name if item.tenant else "По умолчанию" }}</td>
                    <td>{{ value_type_labels.get(item.value_type, "-") }}</td>
                    <td>{{ item.value or "-" }}</td>
                    <td class="actions">
                        <button class="edit-btn" onclick="openEditRuleModal({{ item.id }}, {{ item.object_id }}, '{{ item.utility_type }}', '{{ item.mode }}', '{{ item.base_area_mode }}', '{{ item.tenant_id or '' }}', '{{ item.value_type or '' }}', '{{ item.value or '' }}')">✏️ Изменить</button>
                        <form method="post" action="/rules/{{ item.id }}/delete" style="margin: 0;" onsubmit="return confirm('Вы уверены? Удаление правила приведет к перерасчету начислений.');">
                            <button type="submit" class="delete-btn-inline">❌</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7">Правил пока нет.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<dialog id="edit-charge-dialog">
    <div class="modal-header">
        <h3>Редактировать счет</h3>
        <button class="btn-close" onclick="document.getElementById('edit-charge-dialog').close()">×</button>
    </div>
    <form id="edit-charge-form" method="post" action="">
        <label>Объект
            <select id="edit-charge-object" name="object_id" required>
                {% for item in objects %}<option value="{{ item.id }}">{{ item.name }}</option>{% endfor %}
            </select>
        </label>
        <label>Период
            <select id="edit-charge-period" name="billing_period_id" required>
                {% for item in periods %}<option value="{{ item.id }}">{{ item.month_label or (item.start_date ~ " - " ~ item.end_date) }}</option>{% endfor %}
            </select>
        </label>
        <label>Услуга
            <select id="edit-charge-utility" name="utility_type">
                {% for key, label in utility_labels.items() %}<option value="{{ key }}">{{ label }}</option>{% endfor %}
            </select>
        </label>
        <label>Ввод
            <select id="edit-charge-input-mode" name="input_mode">
                <option value="amount">Итоговой суммой</option>
                <option value="meter">По счетчику</option>
            </select>
        </label>
        <label>Распределение
            <select id="edit-charge-allocation-mode" name="allocation_mode">
                <option value="area">По площади</option>
                <option value="manual">Вручную</option>
                <option value="mixed">Смешанное</option>
            </select>
        </label>
        <label>Сумма<input id="edit-charge-amount" name="amount" type="number" step="0.01"></label>
        <label>Показание от<input id="edit-charge-meter-from" name="meter_from" type="number" step="0.001"></label>
        <label>Показание до<input id="edit-charge-meter-to" name="meter_to" type="number" step="0.001"></label>
        <label>Тариф<input id="edit-charge-tariff" name="tariff" type="number" step="0.0001"></label>
        <label>Ед. изм.<input id="edit-charge-unit" name="unit_name"></label>
        <label>Комментарий<textarea id="edit-charge-comment" name="comment" rows="3"></textarea></label>
        <button type="submit">Сохранить изменения</button>
    </form>
</dialog>

<dialog id="edit-rule-dialog">
    <div class="modal-header">
        <h3>Редактировать правило</h3>
        <button class="btn-close" onclick="document.getElementById('edit-rule-dialog').close()">×</button>
    </div>
    <form id="edit-rule-form" method="post" action="">
        <label>Объект
            <select id="edit-rule-object" name="object_id" required>
                {% for item in objects %}<option value="{{ item.id }}">{{ item.name }}</option>{% endfor %}
            </select>
        </label>
        <label>Услуга
            <select id="edit-rule-utility" name="utility_type">
                {% for key, label in utility_labels.items() %}<option value="{{ key }}">{{ label }}</option>{% endfor %}
            </select>
        </label>
        <label>Режим
            <select id="edit-rule-mode" name="mode">
                <option value="area">По площади</option>
                <option value="manual">Ручной</option>
                <option value="mixed">Смешанный</option>
            </select>
        </label>
        <label>База площади
            <select id="edit-rule-base-area" name="base_area_mode">
                <option value="active_leases">Сумма активных площадей</option>
                <option value="object_total">Общая площадь объекта</option>
            </select>
        </label>
        <label>Арендатор
            <select id="edit-rule-tenant" name="tenant_id">
                <option value="">Для всех арендаторов</option>
                {% for item in tenants %}<option value="{{ item.id }}">{{ item.display_name }}</option>{% endfor %}
            </select>
        </label>
        <label>Тип значения
            <select id="edit-rule-value-type" name="value_type">
                <option value="">Без ручной доли</option>
                <option value="percent">Процент</option>
                <option value="fixed">Фиксированная сумма</option>
            </select>
        </label>
        <label>Значение<input id="edit-rule-value" name="value" type="number" step="0.01"></label>
        <button type="submit">Сохранить изменения</button>
    </form>
</dialog>

<script>
function openEditChargeModal(id, objectId, billingPeriodId, utilityType, inputMode, allocationMode, amount, meterFrom, meterTo, tariff, unitName, comment) {
    const dialog = document.getElementById('edit-charge-dialog');
    const form = document.getElementById('edit-charge-form');
    form.action = '/charges/' + id + '/edit';
    document.getElementById('edit-charge-object').value = objectId;
    document.getElementById('edit-charge-period').value = billingPeriodId;
    document.getElementById('edit-charge-utility').value = utilityType;
    document.getElementById('edit-charge-input-mode').value = inputMode;
    document.getElementById('edit-charge-allocation-mode').value = allocationMode;
    document.getElementById('edit-charge-amount').value = amount || '';
    document.getElementById('edit-charge-meter-from').value = meterFrom || '';
    document.getElementById('edit-charge-meter-to').value = meterTo || '';
    document.getElementById('edit-charge-tariff').value = tariff || '';
    document.getElementById('edit-charge-unit').value = unitName || '';
    document.getElementById('edit-charge-comment').value = comment || '';
    dialog.showModal();
}

function openEditRuleModal(id, objectId, utilityType, mode, baseAreaMode, tenantId, valueType, value) {
    const dialog = document.getElementById('edit-rule-dialog');
    const form = document.getElementById('edit-rule-form');
    form.action = '/rules/' + id + '/edit';
    document.getElementById('edit-rule-object').value = objectId;
    document.getElementById('edit-rule-utility').value = utilityType;
    document.getElementById('edit-rule-mode').value = mode;
    document.getElementById('edit-rule-base-area').value = baseAreaMode;
    document.getElementById('edit-rule-tenant').value = tenantId || '';
    document.getElementById('edit-rule-value-type').value = valueType || '';
    document.getElementById('edit-rule-value').value = value || '';
    dialog.showModal();
}
</script>
{% endblock %}

