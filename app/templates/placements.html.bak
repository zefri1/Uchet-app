{% extends "base.html" %}
{% block content %}
<section class="hero">
    <div>
        <p class="eyebrow">Связка объект ↔ арендатор</p>
        <h2>Размещение арендаторов</h2>
    </div>
</section>
<section class="grid">
    <form class="card form-card" method="post" action="/placements">
        <h3>Новое размещение</h3>
        {% if error %}
            <div class="form-error">{{ error }}</div>
        {% endif %}
        <label>Объект
            <select name="object_id" required>
                {% for item in objects %}
                    <option value="{{ item.id }}" {% if form_state.object_id == item.id %}selected{% endif %}>{{ item.name }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Арендатор
            <select name="tenant_id" required>
                {% for item in tenants %}
                    <option value="{{ item.id }}" {% if form_state.tenant_id == item.id %}selected{% endif %}>{{ item.display_name }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Адрес аренды<input name="rental_address" value="{{ form_state.rental_address or '' }}" required></label>
        <label>Занимаемая площадь<input name="occupied_area" type="number" step="0.01" value="{{ form_state.occupied_area or '' }}" required></label>
        <label>Дата начала<input name="start_date" type="date" value="{{ form_state.start_date or '' }}" required></label>
        <label>Дата окончания<input name="end_date" type="date" value="{{ form_state.end_date or '' }}"></label>
        <label class="checkbox"><input name="is_active" type="checkbox" {% if form_state.is_active is not defined or form_state.is_active %}checked{% endif %}>Активно</label>
        <button type="submit">Сохранить</button>
    </form>
    <div class="card table-card">
        <h3>История размещений</h3>
        <table>
            <thead><tr><th>Объект</th><th>Арендатор</th><th>Адрес</th><th>Площадь</th><th>Период</th><th>Статус</th><th>Действия</th></tr></thead>
            <tbody>
            {% for item in placements %}
                <tr>
                    <td>{{ item.object.name }}</td>
                    <td>{{ item.tenant.display_name }}</td>
                    <td>{{ item.rental_address }}</td>
                    <td>{{ item.occupied_area }}</td>
                    <td>{{ item.start_date }} - {{ item.end_date or "..." }}</td>
                    <td>{{ "Да" if item.is_active else "Нет" }}</td>
                    <td class="actions">
                        <button class="edit-btn" onclick="openEditPlacementModal({{ item.id }}, {{ item.object_id }}, {{ item.tenant_id }}, '{{ item.rental_address|escape }}', {{ item.occupied_area }}, '{{ item.start_date }}', '{{ item.end_date or '' }}', '{{ item.is_active }}')">✏️ Изменить</button>
                        <form method="post" action="/placements/{{ item.id }}/delete" style="margin: 0;" onsubmit="return confirm('Вы уверены? Удаление договора повлечет автоматический перерасчет текущих периодов.');">
                            <button type="submit" class="delete-btn-inline">❌</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7">Размещений пока нет.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>

<dialog id="edit-placement-dialog">
    <div class="modal-header">
        <h3>Редактировать размещение</h3>
        <button class="btn-close" onclick="document.getElementById('edit-placement-dialog').close()">×</button>
    </div>
    <form id="edit-placement-form" method="post" action="">
        <label>Объект
            <select id="edit-placement-object" name="object_id" required>
                {% for item in objects %}
                    <option value="{{ item.id }}">{{ item.name }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Арендатор
            <select id="edit-placement-tenant" name="tenant_id" required>
                {% for item in tenants %}
                    <option value="{{ item.id }}">{{ item.display_name }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Адрес аренды<input id="edit-placement-address" name="rental_address" required></label>
        <label>Занимаемая площадь<input id="edit-placement-area" name="occupied_area" type="number" step="0.01" required></label>
        <label>Дата начала<input id="edit-placement-start" name="start_date" type="date" required></label>
        <label>Дата окончания<input id="edit-placement-end" name="end_date" type="date"></label>
        <label class="checkbox"><input id="edit-placement-active" name="is_active" type="checkbox">Активно</label>
        <button type="submit">Сохранить изменения</button>
    </form>
</dialog>

<script>
function openEditPlacementModal(id, objectId, tenantId, address, area, start, end, active) {
    const dialog = document.getElementById('edit-placement-dialog');
    const form = document.getElementById('edit-placement-form');
    form.action = '/placements/' + id + '/edit';
    document.getElementById('edit-placement-object').value = objectId;
    document.getElementById('edit-placement-tenant').value = tenantId;
    document.getElementById('edit-placement-address').value = address;
    document.getElementById('edit-placement-area').value = area;
    document.getElementById('edit-placement-start').value = start;
    document.getElementById('edit-placement-end').value = end || '';
    document.getElementById('edit-placement-active').checked = (active === 'True' || active === true);
    dialog.showModal();
}
</script>
{% endblock %}

